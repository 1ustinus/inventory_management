{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastLogin": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "price": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "updatedAt": { "type": "string" }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "total": { "type": "number" },
        "items": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Application users"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory items"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    },
    "/categories/{categoryId}": {
      "schema": "object",
      "description": "Product categories"
    },
    "/suppliers/{supplierId}": {
      "schema": "object",
      "description": "Product suppliers"
    },
    "/notifications/{notificationId}": {
      "schema": "object",
      "description": "System notifications"
    },
    "/audit_logs/{logId}": {
      "schema": "object",
      "description": "System audit logs"
    }
  }
}

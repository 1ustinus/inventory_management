{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "inventory", "cashier"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Store inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "minStockLevel": { "type": "number" },
        "unit": { "type": "string" },
        "imageUrl": { "type": "string" },
        "supplierId": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "stockQuantity"]
    },
    "Sale": {
      "title": "Sale Transaction",
      "description": "Record of a finalized sale",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "cashierId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "gcash", "maya", "card"] },
        "amountReceived": { "type": "number" },
        "change": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "voided"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "cashierId", "items", "total", "paymentMethod"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "code"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product suppliers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts and notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["low_stock", "out_of_stock", "damaged", "expiry", "sale", "account"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System activity logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection of user profiles" },
    "products": { "schema": "Product", "description": "Collection of products in inventory" },
    "sales": { "schema": "Sale", "description": "Collection of sale transactions" },
    "categories": { "schema": "Category", "description": "Collection of product categories" },
    "suppliers": { "schema": "Supplier", "description": "Collection of suppliers" },
    "notifications": { "schema": "Notification", "description": "Collection of system notifications" },
    "audit_logs": { "schema": "AuditLog", "description": "Collection of system activity logs" }
  }
}
